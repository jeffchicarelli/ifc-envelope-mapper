<?xml version="1.0" encoding="utf-8"?>
<!--
  Default test runner settings.

  Skips tests marked [Trait("Category", "Integration")] so a plain
  `dotnet test` runs only the fast unit tests (about 1 s) instead of
  pulling in the IFC-loading integration suite (multi-minute).

  Override via CLI filter:
    dotnet test  filter:Category=Integration   (only integration)
    dotnet test  filter:                        (run everything)

  CI's workflow passes its own filter explicitly, so this file just makes
  the local default match the CI default. Auto-applied via the
  RunSettingsFilePath entry in each test .csproj.
-->
<RunSettings>
  <RunConfiguration>
    <TestCaseFilter>Category!=Integration</TestCaseFilter>
  </RunConfiguration>
</RunSettings>
